{
  "manifest_version": 3,
  "name": "Mood Spicer",
  "version": "1.0",
  "description": "An AI-powered extension to understand your mood and spice it up with jokes and music recommendations.",
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ]
}
